# Spotify OAuth — create app at https://developer.spotify.com/dashboard
# Redirect URI to register in Spotify Dashboard: http://localhost:3000/spotify/callback
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Last.fm API Key (optional — for similar track suggestions)
VITE_LASTFM_API_KEY=your_lastfm_api_key_here

# Supabase
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Super Admin panel password
VITE_SUPERADMIN_PASSWORD=your_superadmin_password_here
